{
  "$schema": "https://turbo.build/schema.json",
  "version": "1",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    }
  }
}
